# auto-story-tools configuration
# ─────────────────────────────────────────────
# Default mode: plain provider API keys.
# Set ONE provider key and run.

ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Generic bridge mode (optional)
# Use this when running through a proxy, gateway, or OAuth-backed bridge.
# If AUTO_OUTLINE_API_KEY is set, pair it with AUTO_OUTLINE_PROVIDER.
#
# AUTO_OUTLINE_PROVIDER=openai
# AUTO_OUTLINE_API_KEY=bridge-token
# AUTO_OUTLINE_API_BASE=https://your-proxy.example.com
# AUTO_OUTLINE_AUTH_HEADER=Authorization
# AUTO_OUTLINE_AUTH_SCHEME=Bearer

# ─────────────────────────────────────────────
# Model overrides (optional)
#
# Draft model: used for generating story content (faster, cheaper)
# Eval model: used for judging quality (should differ from draft to avoid self-congratulation)
#
# AUTO_OUTLINE_DRAFT_MODEL=claude-sonnet-4-6
# AUTO_OUTLINE_EVAL_MODEL=claude-opus-4-6

# ─────────────────────────────────────────────
# Custom API base URL (optional)
# Useful for proxies, local models, or alternative endpoints
#
# AUTO_OUTLINE_API_BASE=https://api.anthropic.com

# auto-story-tools configuration
# ─────────────────────────────────────────────
# Set ONE API key (Anthropic recommended for best results):

ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ─────────────────────────────────────────────
# Model overrides (optional)
#
# Draft model: used for generating story content (faster, cheaper)
# Eval model: used for judging quality (should differ from draft to avoid self-congratulation)
#
# AUTO_OUTLINE_DRAFT_MODEL=claude-sonnet-4-6
# AUTO_OUTLINE_EVAL_MODEL=claude-opus-4-6

# ─────────────────────────────────────────────
# Custom API base URL (optional)
# Useful for proxies, local models, or alternative endpoints
#
# AUTO_OUTLINE_API_BASE=https://api.anthropic.com
